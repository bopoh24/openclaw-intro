# Copy to .env and fill in the values
# cp .env.example .env

# Docker image (defaults to latest from GHCR)
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Token for accessing the Control UI
# Leave empty to auto-generate on first deploy
OPENCLAW_GATEWAY_TOKEN=

# Trello skill
# API Key: https://trello.com/power-ups/admin
# Token: https://trello.com/1/authorize?expiration=never&scope=read,write&response_type=token&name=OpenClaw&key=YOUR_API_KEY
TRELLO_API_KEY=
TRELLO_TOKEN=

